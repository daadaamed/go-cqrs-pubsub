# Copy to .env and adjust if needed.
DATABASE_URL=postgres://todo:todo@localhost:5432/todo?sslmode=disable
PORT=8080

# Pub/Sub emulator. Setting PUBSUB_EMULATOR_HOST makes the client talk to the
# local emulator and skip authentication entirely.
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=todo-local
PUBSUB_TOPIC=todo-events
PUBSUB_SUBSCRIPTION=todo-projection

# Where the emulator delivers push deliveries. host.docker.internal points back
# to the host where the Go app runs (Docker Desktop on macOS).
PUSH_ENDPOINT=http://host.docker.internal:8080/events